# MongoDB Atlas 连接字符串
# ⚠️ 注意：添加数据库名称 "animap"
# 格式：mongodb+srv://用户名:密码@cluster.xxx.mongodb.net/数据库名?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://username:password@cluster0.xxx.mongodb.net/animap?retryWrites=true&w=majority"

# JWT 密钥（用于用户认证）
# 生成方式：openssl rand -base64 32
JWT_SECRET="your-jwt-secret-key-change-this-in-production"

# 服务器端口
PORT=3001

# CORS 配置（前端域名）
# 本地开发：http://localhost:5173
# 生产环境：https://your-frontend-domain.vercel.app
CORS_ORIGIN="http://localhost:5173"

# AI API 配置（可选，用于 AI 客服功能）
# 获取方式：访问 https://console.groq.com/ 创建 API Key
LLM_API_KEY="your-groq-api-key"
LLM_API_BASE="https://api.groq.com/openai/v1"

# Google Maps API（可选，用于地图功能）
# 获取方式：访问 https://console.cloud.google.com/ 创建 API Key
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
