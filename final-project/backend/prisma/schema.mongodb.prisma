// MongoDB 版本的 Prisma Schema
// 注意：MongoDB 与 PostgreSQL 有一些差异，需要调整

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// MongoDB 使用 @db.ObjectId 和 @map 来映射字段
model User {
  id               String             @id @default(auto()) @map("_id") @db.ObjectId
  email            String             @unique
  password         String
  name             String?
  avatar           String?
  bio              String?
  favorites        Favorite[]
  favoriteAnimes   FavoriteAnime[]
  comments         Comment[]
  commentLikes     CommentLike[]
  animeRatings     AnimeRating[]
  locationRatings  LocationRating[]
  itineraries      Itinerary[]
  itineraryLikes   ItineraryLike[]
  itineraryComments ItineraryComment[]
  forumPosts       ForumPost[]
  forumReplies     ForumReply[]
  sentMessages     Message[]
  receivedMessages Message[]
  sentFriendRequests     FriendRequest[]
  receivedFriendRequests FriendRequest[]
  friendsAsUser1  Friendship[]
  friendsAsUser2  Friendship[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Anime {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String       @unique
  nameEn      String?
  year        Int?
  genre       String?
  description String?
  coverImage  String?
  locations   Location[]
  ratings     AnimeRating[]
  favoriteAnimes FavoriteAnime[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Location {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  animeId        String          @db.ObjectId
  anime          Anime           @relation(fields: [animeId], references: [id])
  latitude       Float
  longitude      Float
  address        String
  episode        String?
  animeImage     String
  realImage      String
  description    String?
  favorites      Favorite[]
  comments       Comment[]
  locationRatings LocationRating[]
  itineraryItems ItineraryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Favorite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  locationId String   @db.ObjectId
  location   Location @relation(fields: [locationId], references: [id])
  createdAt  DateTime @default(now())
  
  @@unique([userId, locationId])
  @@index([userId])
  @@index([locationId])
}

model Comment {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  locationId  String        @db.ObjectId
  location    Location      @relation(fields: [locationId], references: [id])
  userId      String        @db.ObjectId
  user        User          @relation(fields: [userId], references: [id])
  content     String
  rating      Int?
  parentId    String?       @db.ObjectId
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]     @relation("CommentReplies")
  likes       CommentLike[]
  photos      CommentPhoto[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([locationId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  commentId String   @db.ObjectId
  comment   Comment  @relation(fields: [commentId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  
  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommentPhoto {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  commentId String   @db.ObjectId
  comment   Comment  @relation(fields: [commentId], references: [id])
  url       String
  createdAt DateTime @default(now())
  
  @@index([commentId])
}

model Itinerary {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  userId      String             @db.ObjectId
  user        User               @relation(fields: [userId], references: [id])
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  transport   String
  isPublic    Boolean            @default(false)
  items       ItineraryItem[]
  likes       ItineraryLike[]
  comments    ItineraryComment[]
  messages    Message[]
  viewCount   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  @@index([userId])
  @@index([isPublic])
}

model ItineraryItem {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  itineraryId String     @db.ObjectId
  itinerary   Itinerary  @relation(fields: [itineraryId], references: [id])
  locationId  String     @db.ObjectId
  location    Location   @relation(fields: [locationId], references: [id])
  order       Int
  visitDate   DateTime?
  duration    Int?
  notes       String?
  createdAt   DateTime   @default(now())
  
  @@index([itineraryId])
  @@index([locationId])
}

model ItineraryLike {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  itineraryId String    @db.ObjectId
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id])
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  
  @@unique([itineraryId, userId])
  @@index([itineraryId])
  @@index([userId])
}

model ItineraryComment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  itineraryId String    @db.ObjectId
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id])
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  content     String
  createdAt   DateTime  @default(now())
  
  @@index([itineraryId])
  @@index([userId])
}

model ForumPost {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @db.ObjectId
  user        User          @relation(fields: [userId], references: [id])
  title       String
  content     String
  category    String?
  viewCount   Int           @default(0)
  likeCount   Int           @default(0)
  replies     ForumReply[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([userId])
  @@index([category])
}

model ForumReply {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  postId      String     @db.ObjectId
  post        ForumPost  @relation(fields: [postId], references: [id])
  userId      String     @db.ObjectId
  user        User       @relation(fields: [userId], references: [id])
  content     String
  parentId    String?    @db.ObjectId
  parent      ForumReply? @relation("ReplyReplies", fields: [parentId], references: [id])
  replies     ForumReply[] @relation("ReplyReplies")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([postId])
  @@index([userId])
}

model AnimeRating {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  animeId   String   @db.ObjectId
  anime     Anime    @relation(fields: [animeId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([animeId, userId])
  @@index([animeId])
  @@index([userId])
}

model LocationRating {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  locationId String   @db.ObjectId
  location   Location @relation(fields: [locationId], references: [id])
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  rating     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@unique([locationId, userId])
  @@index([locationId])
  @@index([userId])
}

model FavoriteAnime {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  animeId   String   @db.ObjectId
  anime     Anime    @relation(fields: [animeId], references: [id])
  createdAt DateTime @default(now())
  
  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
}

model Friendship {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user1Id   String   @db.ObjectId
  user1     User     @relation("User1Friendships", fields: [user1Id], references: [id])
  user2Id   String   @db.ObjectId
  user2     User     @relation("User2Friendships", fields: [user2Id], references: [id])
  createdAt DateTime @default(now())
  
  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model FriendRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId  String   @db.ObjectId
  sender    User     @relation("SentFriendRequests", fields: [senderId], references: [id])
  receiverId String   @db.ObjectId
  receiver  User     @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

model Message {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String     @db.ObjectId
  sender      User       @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String     @db.ObjectId
  receiver    User       @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content     String
  isRead      Boolean    @default(false)
  itineraryId String?    @db.ObjectId
  itinerary   Itinerary? @relation(fields: [itineraryId], references: [id])
  createdAt   DateTime   @default(now())
  
  @@index([senderId])
  @@index([receiverId])
  @@index([itineraryId])
}



