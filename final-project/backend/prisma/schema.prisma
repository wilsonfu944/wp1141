// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  password         String
  name             String?
  avatar           String?            // 頭像 URL
  bio              String?            // 個人簡介
  favorites        Favorite[]
  favoriteAnimes   FavoriteAnime[]
  comments         Comment[]
  commentLikes     CommentLike[]
  animeRatings     AnimeRating[]
  locationRatings  LocationRating[] @relation("LocationRatings")
  itineraries      Itinerary[]
  itineraryLikes   ItineraryLike[]
  itineraryComments ItineraryComment[]
  forumPosts       ForumPost[]
  forumReplies     ForumReply[]
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  friendsAsUser1  Friendship[]       @relation("User1Friendships")
  friendsAsUser2  Friendship[]       @relation("User2Friendships")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Anime {
  id          String       @id @default(cuid())
  name        String       @unique
  nameEn      String?      // 英文名稱
  year        Int?         // 年份
  genre       String?      // 類型
  description String?      // 簡介
  coverImage  String?      // 封面圖 URL
  locations   Location[]
  ratings     AnimeRating[]
  favoriteAnimes FavoriteAnime[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Location {
  id             String          @id @default(cuid())
  name           String
  animeId        String
  anime          Anime           @relation(fields: [animeId], references: [id], onDelete: Cascade)
  latitude       Float
  longitude      Float
  address        String
  episode        String?         // 出現集數
  animeImage     String          // 動畫截圖 URL
  realImage      String          // 真實照片 URL
  description    String?         // 描述
  favorites      Favorite[]
  comments       Comment[]
  locationRatings LocationRating[]
  itineraryItems ItineraryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  
  @@unique([userId, locationId]) // 防止重複收藏
}

model Comment {
  id          String        @id @default(cuid())
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String        // 評論內容
  rating      Int?          // 評分 1-5
  parentId    String?       // 回覆的父評論 ID
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]     @relation("CommentReplies")
  likes       CommentLike[]
  photos      CommentPhoto[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([commentId, userId])
}

model CommentPhoto {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  url       String   // 照片 URL
  createdAt DateTime @default(now())
}

model Itinerary {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String             // 行程名稱
  description String?            // 行程描述
  startDate   DateTime?          // 開始日期
  endDate     DateTime?          // 結束日期
  transport   String             // 交通方式: walking, public, driving
  isPublic    Boolean            @default(false) // 是否公開
  items       ItineraryItem[]
  likes       ItineraryLike[]
  comments    ItineraryComment[]
  messages    Message[]          // 相關私訊
  viewCount   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ItineraryItem {
  id          String     @id @default(cuid())
  itineraryId String
  itinerary   Itinerary  @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  order       Int        // 排序順序（優化後的順序）
  visitDate   DateTime?  // 預計參訪日期時間
  duration    Int?       // 預計停留時間（分鐘）
  notes       String?    // 個人筆記
  createdAt   DateTime   @default(now())
}

model ItineraryLike {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  
  @@unique([itineraryId, userId])
}

model ItineraryComment {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime  @default(now())
}

// 留言板（論壇）功能
model ForumPost {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String        // 標題
  content     String        // 內容
  category    String?       // 分類（如：找旅伴、討論、分享等）
  viewCount   Int           @default(0)
  likeCount   Int           @default(0)
  replies     ForumReply[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ForumReply {
  id          String     @id @default(cuid())
  postId      String
  post        ForumPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String     // 回覆內容
  parentId    String?    // 回覆的父回覆 ID（支援多層回覆）
  parent      ForumReply? @relation("ReplyReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     ForumReply[] @relation("ReplyReplies")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// 動漫評分
model AnimeRating {
  id        String   @id @default(cuid())
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 評分 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([animeId, userId]) // 每個用戶對每個動漫只能評分一次
}

// 地點評分（獨立於評論評分）
model LocationRating {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("LocationRatings", fields: [userId], references: [id], onDelete: Cascade)
  rating     Int      // 評分 1-5
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@unique([locationId, userId]) // 每個用戶對每個地點只能評分一次
}

// 喜歡的動畫（非聖地）
model FavoriteAnime {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, animeId]) // 防止重複收藏
}

// 好友關係
model Friendship {
  id        String   @id @default(cuid())
  user1Id   String
  user1     User     @relation("User1Friendships", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("User2Friendships", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([user1Id, user2Id]) // 防止重複好友關係
  @@index([user1Id])
  @@index([user2Id])
}

// 好友請求
model FriendRequest {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver  User     @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([senderId, receiverId]) // 防止重複請求
  @@index([receiverId, status])
}

// 私訊功能
model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content     String   // 訊息內容
  isRead      Boolean  @default(false)
  itineraryId String?  // 關聯的行程 ID（方便找旅伴）
  itinerary   Itinerary? @relation(fields: [itineraryId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

